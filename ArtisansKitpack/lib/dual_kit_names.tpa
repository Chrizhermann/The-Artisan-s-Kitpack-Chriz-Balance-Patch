COPY_EXISTING ~enginest.2da~ ~override~
  COUNT_2DA_ROWS 2 rows
  FOR (row = 0 ; row < rows ; ++row) BEGIN
    READ_2DA_ENTRY row 0 2 entry
    PATCH_IF (("%entry%" STRING_COMPARE_CASE "STRREF_GUI_MIXED_KIT_MAGESCHOOL_GENERALIST"      = 0)) BEGIN
      FOR (col = 1; col < 2 ; ++col) BEGIN
        READ_2DA_ENTRY row 1 2 name
          GET_STRREF %name% mage_name
    END
    END
  END
  PRETTY_PRINT_2DA
  BUT_ONLY

COPY_EXISTING ~CLASTEXT.2DA~ ~override~
      COUNT_2DA_COLS col_count
      COUNT_2DA_ROWS col_count rows
  READ_2DA_ENTRIES_NOW ~clastext~ 10
      FOR (index = 0; index < rows; ++index) BEGIN
  READ_2DA_ENTRY_FORMER ~clastext~ index 0 class_id
  READ_2DA_ENTRY_FORMER ~clastext~ index 5 class_name

PATCH_IF 
				("%class_id%" STRING_EQUAL_CASE "CLERIC") BEGIN
GET_STRREF %class_name% cleric_name
END

PATCH_IF 
				("%class_id%" STRING_EQUAL_CASE "THIEF") BEGIN
GET_STRREF %class_name% thief_name
END

PATCH_IF 
				("%class_id%" STRING_EQUAL_CASE "RANGER") BEGIN
GET_STRREF %class_name% ranger_name
END

PATCH_IF 
				("%class_id%" STRING_EQUAL_CASE "DRUID") BEGIN
GET_STRREF %class_name% druid_name
END

END

COPY_EXISTING ~KITLIST.2DA~ ~override~
  READ_2DA_ENTRIES_NOW ~fig_kitlist~ 10
  FOR (row = 1; row < fig_kitlist; row += 1) BEGIN
  READ_2DA_ENTRY_FORMER ~fig_kitlist~ row 5 kit_clab
  READ_2DA_ENTRY_FORMER ~fig_kitlist~ row 0 kit_number
  READ_2DA_ENTRY_FORMER ~fig_kitlist~ row 1 kit_label
  READ_2DA_ENTRY_FORMER ~fig_kitlist~ row 3 kit_mixed
  READ_2DA_ENTRY_FORMER ~fig_kitlist~ row 8 kit_class
  READ_2DA_ENTRY_FORMER ~fig_kitlist~ row 9 kit_ids

PATCH_IF FILE_EXISTS_IN_GAME ~%kit_clab%.2da~ BEGIN
  PATCH_IF ((kit_class = 2) OR (kit_class = 3) OR (kit_class = 4) OR (kit_class = 11) OR (kit_class = 12)) BEGIN
  INNER_ACTION BEGIN
COPY ~ArtisansKitpack/spells/C0KT#NA.SPL~ ~override~
    LPF GET_UNIQUE_FILE_NAME STR_VAR extension = "SPL" base = EVAL "C0KT_%kit_number%" RET abil_new_name = filename END
    INNER_PATCH_SAVE abil_new_name "%abil_new_name%" BEGIN REPLACE_TEXTUALLY CASE_INSENSITIVE EXACT_MATCH ~__~ ~C0KT~ END
COPY_EXISTING ~%kit_clab%.2DA~ override
        REPLACE_TEXTUALLY ~AP_C0PR#CL~ ~****      ~
        LPF set_clab_2da_entries INT_VAR f_MinLevel = 1 f_MaxLevel = 1 STR_VAR f_Entry = EVAL ~AP_%abil_new_name%~ END
        PRETTY_PRINT_2DA

COPY_EXISTING ~C0KT#NA.SPL~ ~override/%abil_new_name%.SPL~
  
END

