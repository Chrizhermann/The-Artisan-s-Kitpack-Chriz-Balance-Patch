    INNER_PATCH_SAVE abil_new_name_f_m_t "%abil_new_name_f_m_t%" BEGIN REPLACE_TEXTUALLY CASE_INSENSITIVE EXACT_MATCH ~__~ ~C0KT~ END
    LPF GET_UNIQUE_FILE_NAME STR_VAR extension = "EFF" base = EVAL "C0KT_%kit_number%_FIGHTER_MAGE_CLERIC" RET abil_new_name_f_m_c = filename END
    INNER_PATCH_SAVE abil_new_name_f_m_c "%abil_new_name_f_m_c%" BEGIN REPLACE_TEXTUALLY CASE_INSENSITIVE EXACT_MATCH ~__~ ~C0KT~ END

COPY_EXISTING ~C0KT#NA.EFF~ ~override/%abil_new_name_f_m%.EFF~
GET_STRREF %kit_mixed% kit_name
WRITE_LONG 0x1c RESOLVE_STR_REF (~%kit_name% / %mage_name%~)
WRITE_LONG 0x48 7

COPY_EXISTING ~C0KT#NA.EFF~ ~override/%abil_new_name_f_c%.EFF~
GET_STRREF %kit_mixed% kit_name
WRITE_LONG 0x1c RESOLVE_STR_REF (~%kit_name% / %cleric_name%~)
WRITE_LONG 0x48 8

COPY_EXISTING ~C0KT#NA.EFF~ ~override/%abil_new_name_f_t%.EFF~
GET_STRREF %kit_mixed% kit_name
WRITE_LONG 0x1c RESOLVE_STR_REF (~%kit_name% / %thief_name%~)
WRITE_LONG 0x48 9

COPY_EXISTING ~C0KT#NA.EFF~ ~override/%abil_new_name_f_d%.EFF~
GET_STRREF %kit_mixed% kit_name
WRITE_LONG 0x1c RESOLVE_STR_REF (~%kit_name% / %druid_name%~)
WRITE_LONG 0x48 16

COPY_EXISTING ~C0KT#NA.EFF~ ~override/%abil_new_name_f_m_t%.EFF~
GET_STRREF %kit_mixed% kit_name
WRITE_LONG 0x1c RESOLVE_STR_REF (~%kit_name% / %mage_name% / %thief_name%~)
WRITE_LONG 0x48 10

COPY_EXISTING ~C0KT#NA.EFF~ ~override/%abil_new_name_f_m_c%.EFF~
GET_STRREF %kit_mixed% kit_name
WRITE_LONG 0x1c RESOLVE_STR_REF (~%kit_name% / %mage_name% / %cleric_name%~)
WRITE_LONG 0x48 17

COPY_EXISTING ~%abil_new_name%.SPL~ ~override~
  LPF ADD_SPELL_EFFECT INT_VAR target = 1 opcode = 321 timing = 1 STR_VAR resource = EVAL ~%SOURCE_RES%~ END
  LPF ADD_SPELL_EFFECT INT_VAR target = 1 opcode = 177 parameter1 = 7 parameter2 = 5 timing = 9 STR_VAR resource = EVAL ~%abil_new_name_f_m%~ END
  LPF ADD_SPELL_EFFECT INT_VAR target = 1 opcode = 177 parameter1 = 8 parameter2 = 5 timing = 9 STR_VAR resource = EVAL ~%abil_new_name_f_c%~ END
  LPF ADD_SPELL_EFFECT INT_VAR target = 1 opcode = 177 parameter1 = 9 parameter2 = 5 timing = 9 STR_VAR resource = EVAL ~%abil_new_name_f_t%~ END
  LPF ADD_SPELL_EFFECT INT_VAR target = 1 opcode = 177 parameter1 = 16 parameter2 = 5 timing = 9 STR_VAR resource = EVAL ~%abil_new_name_f_d%~ END
  LPF ADD_SPELL_EFFECT INT_VAR target = 1 opcode = 177 parameter1 = 10 parameter2 = 5 timing = 9 STR_VAR resource = EVAL ~%abil_new_name_f_m_t%~ END
  LPF ADD_SPELL_EFFECT INT_VAR target = 1 opcode = 177 parameter1 = 17 parameter2 = 5 timing = 9 STR_VAR resource = EVAL ~%abil_new_name_f_m_c%~ END
  
END
END

